{
  "extends": "airbnb",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "env": {
    "browser": true,
    "node": true
  },
  "rules": {
    "semi": [
      "error",
      "always"
    ],
    "quotes": [
      "error",
      "double"
    ],
    "no-console": "warn",
    "no-unused-vars": "warn",
    "no-undef": "error",
    "indent": [
      "error",
      2
    ],
    "no-mixed-spaces-and-tabs": "error",
    "comma-dangle": [
      "error",
      "always-multiline"
    ],
    "no-trailing-spaces": "error"
  }
}
